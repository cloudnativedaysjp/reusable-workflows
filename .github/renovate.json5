{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'github>aquaproj/aqua-renovate-config#2.8.2',
  ],
  labels: [
    'dependencies',
  ],
  packageRules: [
    {
      matchManagers: [
        'github-actions',
      ],
      groupName: 'all dependencies on GitHub Actions',
    },
  ],
  enabledManagers: [
    'github-actions',
    'custom.regex',
  ],
}
